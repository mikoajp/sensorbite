<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude auto-generated code -->
    <Match>
        <Package name="~.*\.generated\..*"/>
    </Match>
    
    <!-- Exclude configuration classes -->
    <Match>
        <Class name="~.*\.config\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    
    <!-- Exclude DTOs - they are intentionally simple -->
    <Match>
        <Class name="~.*\.dto\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,URF_UNREAD_FIELD"/>
    </Match>
    
    <!-- Exclude test classes -->
    <Match>
        <Class name="~.*Test"/>
    </Match>
    
    <!-- Allow serialization without serialVersionUID in DTOs -->
    <Match>
        <Class name="~.*DTO"/>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>
    
    <!-- Spring Boot application class -->
    <Match>
        <Class name="com.sensorbite.Main"/>
        <Bug pattern="IMC_IMMATURE_CLASS_NO_TOSTRING"/>
    </Match>
</FindBugsFilter>
